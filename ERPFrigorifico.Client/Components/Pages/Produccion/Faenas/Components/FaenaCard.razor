@using ERPFrigorifico.Client.ApiClients
@using ERPFrigorifico.Client.Extensiones
@using ERPFrigorifico.Shared.DTOs.Faenas
@using ERPFrigorifico.Shared.Enums
@inject FaenaApi faenaApi

<MudCard>
    <MudCardMedia Image="images/door.jpg" Height="200" />
    <MudCardContent>
        <MudText Typo="Typo.h5">@faenaResponse?.FechaProduccion</MudText>
        <MudText Typo="Typo.body2">@faenaResponse?.TipoFaena</MudText>
        <MudText Typo="Typo.body2">This photo was taken in a small village in Istra Croatia.</MudText>
    </MudCardContent>
    <MudCardActions>
        @if (faenaResponse?.TipoFaena == TipoFaena.Pendiente)
        {
            <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="@(() => ProcesarFaena(faenaResponse.Id))">>Comenzar proceso</MudButton>
        }
        else if (faenaResponse?.TipoFaena == TipoFaena.EnCurso)
        {
            <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="@(() => TerminarFaena(faenaResponse.Id))">>Finalizar proceso</MudButton>
        }
    </MudCardActions>
</MudCard>

@code {

    private FaenaResponse? faenaResponse { get; set; }
    private string? Error;

    protected override async Task OnInitializedAsync()
    => await TraerFaenaEnProceso();

    //Necesito 3 metodos, uno para listar, otro para comenzar y otro para detener.
    public async Task TraerFaenaEnProceso()
    {
        Error = null;

        try
        {
            faenaResponse = await faenaApi.GetFaenaEnProceso();
        }
        catch (HttpApiException ex)
        {
            Error = ex.Message;
        }
    }

    public async Task ProcesarFaena(int id)
    {
        try
        {
            await faenaApi.ProcesarFaena(id);
        }
        catch (HttpApiException ex)
        {
            Error = ex.Message;
        }
    }

    public async Task TerminarFaena(int id)
    {
        try
        {
            await faenaApi.TerminarFaena(id);
        }
        catch (HttpApiException ex)
        {
            Error = ex.Message;
        }
    }

}
