@using ERPFrigorifico.Client.ApiClients
@using ERPFrigorifico.Client.Extensiones
@using ERPFrigorifico.Shared.DTOs.MovimientosAnimales
@inject MovimientoAnimalApi movimientoAnimalApi

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.History" Class="mr-3 mb-n1" />
            Historial del Animal #@AnimalId
        </MudText>
    </TitleContent>
    
    <DialogContent>
        @if (Loading)
        {
            <div class="d-flex justify-center align-center w-100 py-8">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else if (animalByIdResponses == null || !animalByIdResponses.Any())
        {
            <MudAlert Severity="Severity.Info">No se encontraron movimientos para este animal.</MudAlert>
        }
        else
        {
            <MudTable Items="@animalByIdResponses" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0" Dense="true">
                <HeaderContent>
                    <MudTh>Fecha</MudTh>
                    <MudTh>Tipo de Movimiento</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Fecha">@context.FechaMovimiento.ToString("dd/MM/yyyy HH:mm")</MudTd>
                    <MudTd DataLabel="Tipo">
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text">
                            @context.TipoMovimiento
                        </MudChip>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cerrar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">Entendido</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }
    private bool Loading;
    private string? Error;

    protected override async Task OnInitializedAsync()
    => await HistorialAnimalId();

    private List<MovimientoAnimalByIdResponse>? animalByIdResponses = new();

    [Parameter]
    public int AnimalId { get; set; }

    private async Task HistorialAnimalId()
    {
        Loading = true;
        Error = null;
        try
        {
            animalByIdResponses = await movimientoAnimalApi.GetAllMovimientosAnimales(AnimalId);
        }
        catch (HttpApiException ex)
        {
            Error = ex.Message;
        }
        finally
        {
            Loading = false;
        }
    }


    private void Submit() => MudDialog.Close(DialogResult.Ok(true));

    private void Cancel() => MudDialog.Cancel();
}
